<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="view.DashboardController"
            prefHeight="680.0" prefWidth="950.0">

    <top>
        <VBox style="-fx-background-color: #2c3e50;">
            <Label text="Sistem Pengelolaan Batik"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 12 0 12 18;"/>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <!-- ======================== TAB SUPPLIER ======================== -->
            <Tab text="Supplier">
                <VBox spacing="12" style="-fx-padding: 15;">

                    <Label text="Manajemen Supplier"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <TableView fx:id="tabelSupplier" prefHeight="230" prefWidth="910">
                        <columns>
                            <TableColumn fx:id="kolSupplierId" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="kolSupplierNama" text="Nama" prefWidth="220"/>
                            <TableColumn fx:id="kolSupplierTelepon" text="Telepon" prefWidth="160"/>
                            <TableColumn fx:id="kolSupplierAlamat" text="Alamat" prefWidth="350"/>
                        </columns>
                        <placeholder><Label text="Belum ada data supplier"/></placeholder>
                    </TableView>

                    <GridPane hgap="12" vgap="8">
                        <Label text="Nama :"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"
                               minWidth="80"/>
                        <TextField fx:id="tfSupplierNama" promptText="Nama supplier"
                                   prefWidth="320"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Telepon :"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"
                               minWidth="80"/>
                        <TextField fx:id="tfSupplierTelepon" promptText="Min 10 digit angka"
                                   prefWidth="320"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Alamat :"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"
                               minWidth="80"/>
                        <TextField fx:id="tfSupplierAlamat" promptText="Alamat supplier"
                                   prefWidth="320"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Tambah" onAction="#tambahSupplier"
                                prefWidth="90"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button text="Update" onAction="#updateSupplier"
                                prefWidth="90"
                                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button text="Hapus" onAction="#hapusSupplier"
                                prefWidth="90"
                                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>

                    <Label fx:id="lblSupplierMsg" text="" wrapText="true"
                           style="-fx-font-weight: bold;"/>

                </VBox>
            </Tab>

            <!-- ======================== TAB BAJU ======================== -->
            <Tab text="Baju">
                <VBox spacing="12" style="-fx-padding: 15;">

                    <Label text="Manajemen Baju Batik"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <TableView fx:id="tabelBaju" prefHeight="200" prefWidth="910">
                        <columns>
                            <TableColumn fx:id="kolBajuNama" text="Nama Produk" prefWidth="140"/>
                            <TableColumn fx:id="kolBajuHarga" text="Harga" prefWidth="100"/>
                            <TableColumn fx:id="kolBajuStok" text="Stok" prefWidth="60"/>
                            <TableColumn fx:id="kolBajuMotif" text="Motif" prefWidth="120"/>
                            <TableColumn fx:id="kolBajuUkuran" text="Ukuran" prefWidth="70"/>
                            <TableColumn fx:id="kolBajuKategori" text="Kategori" prefWidth="130"/>
                            <TableColumn fx:id="kolBajuSupplier" text="Supplier" prefWidth="160"/>
                        </columns>
                        <placeholder><Label text="Belum ada data baju"/></placeholder>
                    </TableView>

                    <GridPane hgap="12" vgap="6">
                        <Label text="Nama :"
                               GridPane.columnIndex="0" GridPane.rowIndex="0" minWidth="90"/>
                        <TextField fx:id="tfBajuNama" promptText="Nama baju"
                                   prefWidth="210" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Harga :"
                               GridPane.columnIndex="2" GridPane.rowIndex="0" minWidth="70"/>
                        <TextField fx:id="tfBajuHarga" promptText="Contoh: 150000"
                                   prefWidth="170" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="Stok :"
                               GridPane.columnIndex="0" GridPane.rowIndex="1" minWidth="90"/>
                        <TextField fx:id="tfBajuStok" promptText="Jumlah stok"
                                   prefWidth="210" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Motif :"
                               GridPane.columnIndex="2" GridPane.rowIndex="1" minWidth="70"/>
                        <TextField fx:id="tfBajuMotif" promptText="Contoh: Mega Mendung"
                                   prefWidth="170" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                        <Label text="Ukuran :"
                               GridPane.columnIndex="0" GridPane.rowIndex="2" minWidth="90"/>
                        <TextField fx:id="tfBajuUkuran" promptText="S / M / L / XL"
                                   prefWidth="210" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Kategori :"
                               GridPane.columnIndex="2" GridPane.rowIndex="2" minWidth="70"/>
                        <ComboBox fx:id="cbBajuKategori" promptText="Pilih kategori"
                                  prefWidth="170" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                        <Label text="ID Supplier :"
                               GridPane.columnIndex="0" GridPane.rowIndex="3" minWidth="90"/>
                        <TextField fx:id="tfBajuSupplierId" promptText="ID supplier"
                                   prefWidth="210" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Tambah Baju" onAction="#tambahBaju"
                                prefWidth="110"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button text="Update Baju" onAction="#updateBaju"
                                prefWidth="110"
                                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button text="Hapus Baju" onAction="#hapusBaju"
                                prefWidth="110"
                                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button text="Tambah Stok" onAction="#tambahStok"
                                prefWidth="110"
                                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>

                    <Label fx:id="lblBajuMsg" text="" wrapText="true"
                           style="-fx-font-weight: bold;"/>

                </VBox>
            </Tab>

        </TabPane>
    </center>

</BorderPane>